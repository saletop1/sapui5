<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    controllerName="so.app.controller.Main"
    displayBlock="true">

    <Page enableScrolling="true" showHeader="false">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="📊 Sales Dashboard" level="H5"/>
                    <Text text="Outstanding Orders" class="sapUiTinyMarginBegin"/>
                </contentLeft>
                <contentRight>
                    <Text id="clockText" text="–"/>
                    <Button text="LIVE" enabled="false" type="Accept"/>
                    <Button id="themeToggle" text="🌙" press="onToggleTheme" tooltip="Toggle Dark/Light" class="sapUiTinyMarginBegin" type="Transparent"/>
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <VBox class="sapUiSmallMargin">
                <!-- KPI Cards via HTML -->
                <core:HTML id="kpiRow" content="&lt;div class='kpiRow'&gt;&lt;/div&gt;"/>

                <!-- Two columns: Top Customer and Aging Analysis -->
                <HBox id="twoPanelBox" class="sapUiSmallMarginBottom twoPanelRow" justifyContent="SpaceBetween">
                    <VBox class="sapUiSmallMarginEnd twoPanelCol">
                        <Panel>
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="🏆 Top Customer by Value" level="H5"/>
                                    <ToolbarSpacer/>
                                    <RadioButtonGroup id="sourceGroup" columns="2" select="onSourceChange">
                                        <RadioButton id="rbSemarang" text="Semarang" selected="true"/>
                                        <RadioButton id="rbSurabaya" text="Surabaya"/>
                                    </RadioButtonGroup>
                                </Toolbar>
                            </headerToolbar>
                            <ScrollContainer id="custScrollContainer" height="320px" vertical="true" horizontal="false" width="100%">
                                <core:HTML id="custTableHtml"/>
                            </ScrollContainer>
                        </Panel>
                    </VBox>
                    <VBox class="twoPanelCol">
                        <Panel>
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="⏳ Aging Analysis per Customer" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Text text="Stacked by Days Running" class="sapUiTinyMarginEnd agingSubtitle"/>
                                </Toolbar>
                            </headerToolbar>
                            <core:HTML id="agingTypeFilterBar" content="&lt;div&gt;&lt;/div&gt;"/>
                            <ScrollContainer height="288px" vertical="true" horizontal="false" width="100%">
                                <core:HTML id="agingAnalysisHtml" content="&lt;div&gt;Loading...&lt;/div&gt;"/>
                            </ScrollContainer>
                        </Panel>
                    </VBox>
                </HBox>

                <!-- Detail SO Panel -->
                <Panel>
                    <headerToolbar>
                        <Toolbar>
                            <core:HTML id="selectedBadge" content="&lt;span&gt;&lt;/span&gt;"/>
                        </Toolbar>
                    </headerToolbar>
                    <VBox class="filterBarWrap">
                        <HBox class="filterRow1" alignItems="Center">
                            <Label text="Status:" class="filterLabel"/>
                            <Select id="statusFilter" selectedKey="ALL" change="onStatusFilterChange" class="soSapSelect">
                                <items>
                                    <core:ListItem key="ALL"       text="All Status"/>
                                    <core:ListItem key="New"       text="New"/>
                                    <core:ListItem key="Pending"   text="Pending"/>
                                    <core:ListItem key="Low"       text="Low"/>
                                    <core:ListItem key="Medium"    text="Medium"/>
                                    <core:ListItem key="Warning"   text="Warning"/>
                                    <core:ListItem key="Prioritas" text="Prioritas"/>
                                </items>
                            </Select>
                            <Label text="Delivery:" class="filterLabel"/>
                            <core:HTML id="monthFilterBtn" content="&lt;button class='soPickerBtn' onclick='window.__soApp.onDeliveryPickerOpen(this)'&gt;All &#9660;&lt;/button&gt;"/>
                            <Label text="Req. Del:" class="filterLabel"/>
                            <core:HTML id="reqDeliveryFilterBtn" content="&lt;button class='soPickerBtn' onclick='window.__soApp.onReqDeliveryPickerOpen(this)'&gt;All &#9660;&lt;/button&gt;"/>
                        </HBox>
                        <HBox class="filterRow2" alignItems="Center">
                            <SearchField id="searchField" liveChange="onSearch" placeholder="Search SO, customer..." class="soSapSearch"/>
                            <core:HTML content="&lt;button class='soFilterBtn' onclick='window.__soApp.onExportExcel()'&gt;&lt;svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'&gt;&lt;rect x='3' y='3' width='18' height='18' rx='2'/&gt;&lt;path d='M3 9h18M9 21V9'/&gt;&lt;/svg&gt; Excel&lt;/button&gt;"/>
                            <core:HTML content="&lt;button class='soFilterBtn soFilterBtnPdf' onclick='window.__soApp.onExportPdf()'&gt;&lt;svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'&gt;&lt;path d='M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z'/&gt;&lt;polyline points='14,2 14,8 20,8'/&gt;&lt;/svg&gt; PDF&lt;/button&gt;"/>
                            <Text id="rowCount" text="–" class="rowCountText"/>
                        </HBox>
                    </VBox>
                    <VBox id="soScrollContainer" class="soScrollContainer">
                        <Table id="soTable" items="{/resultsPaged}" noDataText="Click a customer above or adjust filters to see SO details" alternateRowColors="true" sticky="ColumnHeaders">
                            <!-- columns dan items sama seperti sebelumnya -->
                            <columns>
                                <Column width="130px"><Text text="Sales Order"/></Column>
                                <Column width="88px" hAlign="Center"><Text text="Created Date"/></Column>
                                <Column width="180px"><Text text="Material"/></Column>
                                <Column width="62px" hAlign="Center"><Text text="Qty Order"/></Column>
                                <Column width="62px" hAlign="Center"><Text text="Shipped"/></Column>
                                <Column width="62px" hAlign="Center"><Text text="Ots. SO"/></Column>
                                <Column width="62px" hAlign="Center"><Text text="Ots. DO"/></Column>
                                <Column width="55px" hAlign="Center"><Text text="Stock WHFG"/></Column>
                                <Column width="58px" hAlign="Center"><Text text="Stock Pack"/></Column>
                                <Column width="85px" hAlign="Center"><Text text="Ots. Value"/></Column>
                                <Column width="88px" hAlign="Center"><Text text="Req. Delivery"/></Column>
                                <Column width="80px" hAlign="Center"><Text text="Days Running"/></Column>
                                <Column width="80px" hAlign="Center"><Text text="Status"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <core:HTML content="{parts: [{path: 'bstnk'}, {path: 'id'}, {path: 'showCustomerBelow'}, {path: 'customer'}], formatter: '.formatSalesOrderWithBstnk'}"/>
                                        <Text text="{orderDateFmt}" wrapping="false" textAlign="Center"/>
                                        <core:HTML content="{parts: [{path: 'matnr'}, {path: 'item'}], formatter: '.formatMaterial'}"/>
                                        <Text text="{kwmengFmt}" wrapping="false" textAlign="Center"/>
                                        <Text text="{qtyGiFmt}" wrapping="false" textAlign="Center"/>
                                        <Text text="{qtyBalance2Fmt}" wrapping="false" textAlign="Center"/>
                                        <Text text="{otsdoFmt}" wrapping="false" textAlign="Center"/>
                                        <Text text="{kalabFmt}" wrapping="false" textAlign="Center"/>
                                        <Text text="{kalab2Fmt}" wrapping="false" textAlign="Center"/>
                                        <Text text="{totalFmt}" wrapping="false" class="priceCell" textAlign="Center"/>
                                        <Text text="{deliveryDateFmt}" wrapping="false" textAlign="Center"/>
                                        <Text text="{hariBerjalan}" wrapping="false" textAlign="Center"/>
                                        <core:HTML content="{path: 'status', formatter: '.formatStatus'}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                        <core:HTML id="paginationHtml" content="&lt;div&gt;&lt;/div&gt;"/>
                    </VBox>
                </Panel>
            </VBox>
        </content>
        <footer>
            <Bar>
                <contentMiddle><Text id="footerInfo" text="Sales Dashboard"/></contentMiddle>
                <contentRight><Text id="footerClock" text="–"/></contentRight>
            </Bar>
        </footer>
    </Page>

    <!-- Dialog Agent -->
    <Dialog id="dlgAgent" title="🤖 AI Sales Agent" contentWidth="450px">
        <content>
            <VBox class="sapUiSmallMargin">
                <Text text="Ask me anything, for example:"/>
                <Text text="• Show SO for ETHAN ALLEN OPERATIONS, INC."/>
                <Text text="• What is the total outstanding value?"/>
                <Text text="• Warning status SO this week"/>
                <TextArea id="agentInput" rows="4" width="100%" placeholder="Type your question..."/>
            </VBox>
        </content>
        <beginButton>
            <Button text="Cancel" press="onAgentClose"/>
        </beginButton>
        <endButton>
            <Button text="Send" type="Emphasized" press=".onAgentProcess"/>
        </endButton>
    </Dialog>
</mvc:View>